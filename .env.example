# ============================================================
# Multi-Flow Voice Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Required: Core API Keys ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Auth (v2) ---
# Generate a strong random SECRET_KEY, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
TOKEN_EXPIRE_HOURS=24

# --- Database (v2) ---
# SQLite (default — no extra setup needed):
DATABASE_URL=sqlite:///./data/agent.db
# PostgreSQL (for production persistent storage):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- inya.ai (6th pipeline — external agent, webhook auth) ---
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
INYA_WEBHOOK_SECRET=your_inya_webhook_secret_here
# Optional: default borrower/agent data returned to inya at call start
# (overrides bot.py DEFAULT_CONFIG for inya calls)
# INYA_AGENT_NAME=Priya
# INYA_COMPANY_NAME=QuickFinance Ltd.
# INYA_BORROWER_NAME=Rajesh Kumar
# INYA_EMI_AMOUNT=5,280
# INYA_TOTAL_DUE=11,760
# INYA_OVERDUE_MONTHS=2

# --- Sarvam AI (5th pipeline — Indian language STT+TTS) ---
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_TTS_MODEL=bulbul:v2           # bulbul:v2 (recommended) | bulbul:v3-beta | bulbul:v3
SARVAM_TTS_VOICE=anushka             # bulbul:v2 voices: anushka, abhilash, manisha, vidya, arya, karun, hitesh (all lowercase)
                                     # bulbul:v2 voices: anushka, manisha, vidya, arya (female)

# --- Groq (5th pipeline — LLM, free tier available) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Ollama (5th pipeline — local LLM, optional) ---
# If set, Ollama takes priority over Groq for the 5th pipeline
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --- OpenAI tuning ---
OPENAI_MODEL=gpt-4o
OPENAI_TTS_VOICE=shimmer

# --- Deepgram tuning ---
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=hi

# --- Edge TTS ---
EDGE_TTS_VOICE=hi-IN-SwaraNeural
EDGE_TTS_RATE=+0%

# --- Twilio (outbound calling — provider option 1) ---
# Get from console.twilio.com. Enable India international calling.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Exotel (outbound calling — provider option 2, India-based) ---
# Get from Exotel dashboard. Lower per-minute rates for India.
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_account_sid
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_PHONE_NUMBER=0XXXXXXXXXX

# --- Required for outbound campaigns: your public deployment URL ---
# Used to build webhook URLs sent to Twilio/Exotel.
# Example: https://multi-flow-voice-agent.onrender.com
PUBLIC_URL=https://your-app.onrender.com

# --- WhatsApp Business Calling API ---
# Get from Meta for Developers → WhatsApp → API Setup
# Set the webhook URL to: https://your-app.onrender.com/whatsapp
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret        # for webhook signature validation
WHATSAPP_VERIFY_TOKEN=any_random_string    # set same value in Meta webhook config

# --- TURN Server (Required for cloud/Render deployment) ---
# Single URL:   turn:global.relay.metered.ca:443
# Multiple URLs: turn:host:80, turn:host:443, turns:host:443?transport=tcp
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
